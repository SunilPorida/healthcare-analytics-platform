# Application
APP_NAME=healthcare-analytics-platform
APP_ENV=development
LOG_LEVEL=INFO

# FastAPI
API_HOST=0.0.0.0
API_PORT=8000

# Snowflake (dev — never commit real secrets)
SNOWFLAKE_ACCOUNT=
SNOWFLAKE_USER=
SNOWFLAKE_PASSWORD=
SNOWFLAKE_ROLE=
SNOWFLAKE_WAREHOUSE=
SNOWFLAKE_DATABASE=
SNOWFLAKE_SCHEMA=

# AWS S3 (production or LocalStack / MinIO)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
# Optional: for local S3-compatible endpoints
# AWS_ENDPOINT_URL=http://localhost:4566

S3_BUCKET_RAW=hcap-raw-dev
S3_BUCKET_PROCESSED=hcap-processed-dev
